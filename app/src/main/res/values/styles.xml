<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.SalesInventory" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryDark</item>
        <item name="colorSecondary">@color/colorAccent</item>
        <item name="colorSecondaryVariant">@color/colorAccent</item>
        <item name="android:statusBarColor">@color/colorPrimaryDark</item>
        <item name="android:windowBackground">@color/backgroundColor</item>
        <item name="android:colorBackground">@color/backgroundColor</item>
        <item name="colorSurface">@color/cardBackground</item>
        <item name="android:navigationBarColor">@color/white</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorError">@color/errorRed</item>
        <item name="colorOnError">@color/white</item>
    </style>

    <style name="AppTheme_Light" parent="Theme.SalesInventory">
        <item name="colorPrimary">#1976D2</item> <item name="colorPrimaryVariant">#1565C0</item>
        <item name="colorSecondary">#FF9800</item>
        <item name="android:windowBackground">#F4F6F8</item> <item name="android:colorBackground">#F4F6F8</item>
        <item name="colorSurface">#FFFFFF</item> <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorOnSecondary">#FFFFFF</item>
        <item name="colorOnBackground">#212121</item> <item name="colorOnSurface">#212121</item>
        <item name="android:statusBarColor">#1565C0</item>
        <item name="android:navigationBarColor">#FFFFFF</item>
    </style>
    <style name="AppTheme" parent="AppTheme_Light" />


    <style name="AppTheme_Colorblind" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">#121212</item>
        <item name="android:colorBackground">#121212</item>
        <item name="colorSurface">#1E1E1E</item> <item name="colorPrimary">#BCAAA4</item> <item name="colorPrimaryVariant">#8D6E63</item>
        <item name="colorSecondary">#FFB74D</item> <item name="colorOnPrimary">#201512</item> <item name="colorOnSecondary">#000000</item>
        <item name="colorOnBackground">#E0E0E0</item> <item name="colorOnSurface">#E0E0E0</item>
        <item name="android:statusBarColor">#000000</item>
        <item name="android:navigationBarColor">#121212</item>
        <item name="colorError">#CF6679</item> <item name="colorOnError">#000000</item>
        <item name="hintTextColor">#9E9E9E</item>
        <item name="android:textColorHint">#9E9E9E</item>
    </style>

    <style name="AppTheme_Dark" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">#121212</item>
        <item name="android:colorBackground">#121212</item>
        <item name="colorSurface">#1E1E1E</item>
        <item name="colorPrimary">#BCAAA4</item>
        <item name="colorPrimaryVariant">#8D6E63</item>
        <item name="colorSecondary">#FFB74D</item>
        <item name="colorOnPrimary">#201512</item>
        <item name="colorOnSecondary">#000000</item>
        <item name="colorOnBackground">#E0E0E0</item>
        <item name="colorOnSurface">#E0E0E0</item>
        <item name="android:statusBarColor">#000000</item>
        <item name="android:navigationBarColor">#121212</item>
        <item name="colorError">#CF6679</item>
        <item name="colorOnError">#000000</item>
        <item name="hintTextColor">#9E9E9E</item>
        <item name="android:textColorHint">#9E9E9E</item>
    </style>

    <style name="DashboardCard">
        <item name="android:layout_margin">8dp</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">4dp</item>
        <item name="cardBackgroundColor">?attr/colorSurface</item>
    </style>

    <style name="DashboardButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="cornerRadius">16dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">11sp</item>
        <item name="android:padding">8dp</item>
        <item name="android:layout_margin">6dp</item>
        <item name="android:backgroundTint">?attr/colorSurface</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="iconTint">?attr/colorOnSurface</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">?attr/colorOnSurface</item>
    </style>

    <style name="CustomTextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">?attr/colorPrimary</item>
        <item name="boxStrokeWidth">2dp</item>
        <item name="boxStrokeErrorColor">?attr/colorError</item>
        <item name="hintTextColor">?attr/colorOnBackground</item>
        <item name="android:textColorHint">?attr/colorPrimary</item>
        <item name="boxCornerRadiusTopStart">8dp</item>
        <item name="boxCornerRadiusTopEnd">8dp</item>
        <item name="boxCornerRadiusBottomStart">8dp</item>
        <item name="boxCornerRadiusBottomEnd">8dp</item>
    </style>

    <style name="CustomButton" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">?attr/colorOnPrimary</item>
        <item name="backgroundTint">?attr/colorPrimary</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <style name="CustomButtonOutlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">?attr/colorOnBackground</item>
        <item name="strokeColor">?attr/colorOnBackground</item>
        <item name="strokeWidth">2dp</item>
        <item name="cornerRadius">12dp</item>
        <item name="backgroundTint">@android:color/transparent</item>
    </style>

    <style name="BottomNavigationViewStyle" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="backgroundTint">?attr/colorSurface</item>
    </style>
</resources>