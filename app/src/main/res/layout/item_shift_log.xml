<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:id="@+id/tvShiftStaffName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Staff Name"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="?attr/colorOnSurface"/>
            <TextView
                android:id="@+id/tvShiftStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ACTIVE"
                android:textStyle="bold"
                android:textSize="12sp"
                android:textColor="?attr/colorPrimary"/>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="8dp"
            android:background="#33888888"/>

        <TextView
            android:id="@+id/tvShiftDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Date: Oct 25, 2023"
            android:textSize="13sp"/>

        <TextView
            android:id="@+id/tvShiftTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Time: 08:00 AM - 05:00 PM"
            android:textSize="13sp"
            android:layout_marginTop="4dp"/>

        <TextView
            android:id="@+id/tvShiftBreak"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Total Break Time: 45 mins"
            android:textSize="13sp"
            android:textColor="?attr/colorPrimary"
            android:layout_marginTop="4dp"/>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>