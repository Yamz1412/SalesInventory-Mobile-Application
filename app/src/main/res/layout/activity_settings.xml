<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="?android:colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnBackground"
            android:layout_marginBottom="24dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Display Preferences" android:textStyle="bold" android:textColor="?attr/colorSecondary" android:layout_marginBottom="8dp"/>

        <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content" app:cardCornerRadius="12dp" app:cardElevation="2dp" android:layout_marginBottom="24dp" app:cardBackgroundColor="?attr/colorSurface">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="?attr/colorOnSurface" android:text="App Theme" android:textStyle="bold" android:textSize="16sp" android:layout_marginBottom="8dp"/>

                <RadioGroup android:id="@+id/rgTheme" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginBottom="16dp">
                    <RadioButton android:id="@+id/rbDefault" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="?attr/colorOnSurface" android:text="Default (Coffee) Mode"/>
                    <RadioButton android:id="@+id/rbLight" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="?attr/colorOnSurface" android:text="Light Mode"/>
                    <RadioButton android:id="@+id/rbDark" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="?attr/colorOnSurface" android:text="Dark Mode"/>
                </RadioGroup>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" android:layout_marginBottom="16dp"/>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchColorblind"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Colorblind Accessibility"
                    android:textSize="16sp"
                    android:textColor="?attr/colorOnSurface"
                    android:textStyle="bold"
                    app:showText="false" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Increases contrast and uses color-safe indicators" android:textSize="12sp" android:textColor="?attr/colorSecondary"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Data Management" android:textStyle="bold" android:textColor="?attr/colorSecondary" android:layout_marginBottom="8dp"/>
        <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content" app:cardCornerRadius="12dp" app:cardElevation="2dp" android:layout_marginBottom="24dp" app:cardBackgroundColor="?attr/colorSurface">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnClearCache"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:text="CLEAR IMAGE &amp; APP CACHE"
                    android:textColor="@color/white"
                    android:backgroundTint="#D32F2F"
                    app:cornerRadius="8dp"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Frees up memory from loaded images to prevent lag."
                    android:textSize="12sp"
                    android:textAlignment="center"
                    android:layout_marginBottom="16dp"
                    android:textColor="?attr/colorOnSurface"
                    android:alpha="0.7"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBackup"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:text="BACKUP DATABASE"
                    style="@style/CustomButton"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRestore"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:text="RESTORE DATABASE"
                    style="@style/CustomButtonOutlined"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnUserManual"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:text="OPEN USER MANUAL"
                    android:textColor="@color/white"
                    android:backgroundTint="#4CAF50"
                    app:cornerRadius="8dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>