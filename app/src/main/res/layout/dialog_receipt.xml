<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:id="@+id/layoutReceiptRoot"
    android:padding="20dp"
    android:background="?attr/colorSurface"
    >

    <ImageView
        android:id="@+id/ivReceiptBusinessLogo"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_gravity="center"
        android:layout_marginBottom="8dp"
        android:scaleType="centerCrop"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvReceiptBusinessName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Store Name"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center"
        android:textColor="?attr/colorOnBackground"
        />

    <TextView
        android:id="@+id/tvReceiptOrderId"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Order ID: #"
        android:textSize="12sp"
        android:gravity="center" />

    <TextView
        android:id="@+id/tvReceiptInvoiceNo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Invoice No: INV-0000"
        android:textSize="12sp"
        android:textStyle="bold"
        android:gravity="center" />

    <TextView
        android:id="@+id/tvReceiptDateTime"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Date &amp; Time: --/--/---- 00:00:00"
        android:textSize="12sp"
        android:gravity="center"
        android:textColor="@color/textColorSecondary"
        android:layout_marginBottom="16dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:id="@+id/lvReceiptItems"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginBottom="8dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE"
        android:layout_marginBottom="8dp" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Total:"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/tvReceiptTotal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:text="₱0.00"
            android:textStyle="bold" />
    </RelativeLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Amount Paid:" />
        <TextView
            android:id="@+id/tvReceiptAmountPaid"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:text="₱0.00" />
    </RelativeLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Payment Method:" />
        <TextView
            android:id="@+id/tvReceiptPaymentMethod"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:text="Cash" />
    </RelativeLayout>

    <RelativeLayout
        android:id="@+id/layoutReceiptChange"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Change:" />
        <TextView
            android:id="@+id/tvReceiptChange"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:text="₱0.00" />
    </RelativeLayout>

    <Button
        android:id="@+id/btnPrintReceipt"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🖨 Print Receipt"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="8dp"
        android:backgroundTint="?attr/colorPrimary"
        android:textColor="@color/white"
        android:visibility="gone"
        android:contentDescription="Print the receipt using a connected printer" />

    <Button
        android:id="@+id/btnFinalizeSale"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Finalize &amp; Save"
        style="@style/CustomButton"
        android:layout_marginTop="8dp" />

</LinearLayout>