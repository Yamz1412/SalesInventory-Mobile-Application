<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="@android:color/white">

        <TextView
            android:id="@+id/tvDialogSupplierName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Supplier Name"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="?attr/colorPrimary"
            android:layout_marginBottom="8dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Categories Handled"
            android:textStyle="bold"
            android:textColor="#424242"
            android:textSize="12sp" />
        <TextView
            android:id="@+id/tvDialogSupplierCategories"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Coffee Beans, Syrups, Milk"
            android:textColor="#212121"
            android:textSize="16sp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Contact Number"
            android:textStyle="bold"
            android:textColor="#424242"
            android:textSize="12sp" />
        <TextView
            android:id="@+id/tvDialogSupplierPhone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0917-123-4567"
            android:textColor="#212121"
            android:textSize="16sp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Email Address"
            android:textStyle="bold"
            android:textColor="#424242"
            android:textSize="12sp" />
        <TextView
            android:id="@+id/tvDialogSupplierEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="contact@supplier.com"
            android:textColor="#212121"
            android:textSize="16sp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Store Address"
            android:textStyle="bold"
            android:textColor="#424242"
            android:textSize="12sp" />
        <TextView
            android:id="@+id/tvDialogSupplierAddress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="123 Coffee Ave, Marikina City"
            android:textColor="#212121"
            android:textSize="16sp"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/btnDialogClose"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:text="Close"
            android:textColor="?attr/colorPrimary" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>