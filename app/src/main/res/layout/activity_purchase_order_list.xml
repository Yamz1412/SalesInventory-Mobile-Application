<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:colorBackground">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:elevation="4dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:backgroundTint="?attr/colorPrimary"
            app:title="Purchase Orders"
            app:titleTextColor="?attr/colorOnPrimary" />
    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        android:weightSum="3"
        android:background="?attr/colorSurface"
        android:elevation="2dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCreatePO"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="Create PO"
            android:textSize="11sp"
            style="@style/CustomButtonOutlined"
            android:textColor="?attr/colorOnPrimary"
            app:backgroundTint="?attr/colorPrimary"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:cornerRadius="6dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddSupplier"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginHorizontal="2dp"
            android:text="Add Supplier"
            android:textSize="11sp"
            android:insetTop="0dp"
            style="@style/CustomButtonOutlined"
            android:insetBottom="0dp"
            android:textColor="@android:color/white"
            app:backgroundTint="#4CAF50"
            app:cornerRadius="6dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnReturnProduct"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="Returns"
            android:textSize="11sp"
            app:backgroundTint="?attr/colorError"
            android:textColor="?attr/colorOnError"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            style="@style/CustomButtonOutlined"
            app:cornerRadius="6dp"/>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewPurchaseOrders"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false"
        tools:listitem="@layout/item_purchase_order"
        android:scrollbars="vertical" />

</LinearLayout>