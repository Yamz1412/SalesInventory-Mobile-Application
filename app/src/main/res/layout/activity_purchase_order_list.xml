<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:colorBackground">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:elevation="4dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:backgroundTint="?attr/colorPrimary"
            app:title="Purchase Orders"
            app:titleTextColor="?attr/colorOnPrimary" />
    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        android:weightSum="4"
        android:background="?attr/colorSurface"
        android:elevation="2dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCreatePO"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="2dp"
            android:text="New PO"
            android:textSize="10sp"
            app:cornerRadius="6dp"
            style="@style/CustomButtonOutlined"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddSupplier"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginHorizontal="2dp"
            android:text="Suppliers"
            android:textSize="10sp"
            android:textColor="@android:color/white"
            app:backgroundTint="#4CAF50"
            app:cornerRadius="6dp"
            style="@style/CustomButtonOutlined"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnReturnProduct"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginHorizontal="2dp"
            android:text="Returns"
            android:textSize="10sp"
            app:backgroundTint="?attr/colorError"
            android:textColor="?attr/colorOnError"
            app:cornerRadius="6dp"
            style="@style/CustomButtonOutlined"/>

        <RelativeLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="2dp"
            android:clipChildren="false"
            android:clipToPadding="false">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnChecklist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Checklist"
                android:textSize="10sp"
                app:backgroundTint="#FF9800"
                android:textColor="@android:color/white"
                app:cornerRadius="6dp"
                style="@style/CustomButtonOutlined"/>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardChecklistBadge"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_alignTop="@id/btnChecklist"
                android:layout_alignEnd="@id/btnChecklist"
                android:layout_marginTop="-6dp"
                android:layout_marginEnd="-4dp"
                app:cardCornerRadius="9dp"
                app:cardBackgroundColor="#D32F2F"
                app:cardElevation="4dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvChecklistBadge"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:text="1" />
            </androidx.cardview.widget.CardView>
        </RelativeLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="4dp"
        android:background="?attr/colorSurface">

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchCompletedOnly"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Show Completed Only"
            android:textSize="12sp"
            android:layout_weight="1"/>

        <ImageButton
            android:id="@+id/btnFilterSortPO"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_filter"
            android:contentDescription="Sort Orders"
            app:tint="?attr/colorPrimary" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewPurchaseOrders"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false"/>

</LinearLayout>