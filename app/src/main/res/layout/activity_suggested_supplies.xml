<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="?android:colorBackground">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarSuggested"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        app:title="Coffee Shop Catalog"
        app:titleTextColor="?attr/colorOnPrimary"
        app:navigationIcon="@android:drawable/ic_menu_revert"
        app:navigationIconTint="?attr/colorOnPrimary"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="?attr/colorSurface"
        android:elevation="4dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Browse standard raw materials and link them to your suppliers."
            android:textSize="13sp"
            android:textColor="?attr/colorOnSurface"
            android:alpha="0.7"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etSearchCatalog"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:background="@drawable/edite_round"
            android:hint="Search catalog..."
            android:textColor="?attr/colorOnSurface"
            android:textColorHint="?attr/colorOnSurface"
            android:inputType="text"
            android:paddingHorizontal="12dp"
            android:drawableStart="@android:drawable/ic_menu_search"
            android:drawablePadding="8dp"
            android:layout_marginBottom="8dp"/>

        <Spinner
            android:id="@+id/spinnerCatalogFilter"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:backgroundTint="?attr/colorControlHighlight"
            android:background="@drawable/edite_round" />
    </LinearLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvSuggestedSupplies"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="8dp"
            android:clipToPadding="false"/>

        <RelativeLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_alignParentEnd="true"
            android:layout_margin="24dp">

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabCart"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_shopping_cart"
                app:backgroundTint="?attr/colorPrimary"
                app:tint="?attr/colorOnPrimary" />

            <TextView
                android:id="@+id/tvCartBadge"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:backgroundTint="#E53935"
                android:background="@drawable/status_badge"
                android:textColor="@android:color/white"
                android:text="0"
                android:textSize="12sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_alignTop="@id/fabCart"
                android:layout_alignEnd="@id/fabCart"
                android:elevation="8dp"
                android:visibility="gone"/>
        </RelativeLayout>

    </RelativeLayout>

</LinearLayout>