<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvDamagedName"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Product Name"
                android:textStyle="bold"
                android:textColor="#212121"
                android:textSize="16sp"/>

            <TextView
                android:id="@+id/tvDamagedLoss"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-₱0.00"
                android:textStyle="bold"
                android:textColor="#D32F2F"
                android:textSize="16sp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#F9FAFB"
            android:padding="12dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvDamagedDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Oct 24, 2023"
                    android:textColor="#9E9E9E"
                    android:textSize="12sp"/>

                <TextView
                    android:id="@+id/tvDamagedReason"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Reason: Spoiled"
                    android:textColor="#757575"
                    android:textSize="13sp"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvDamagedQty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lost: 5 units"
                android:textColor="#D32F2F"
                android:textStyle="bold"
                android:textSize="13sp"/>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>