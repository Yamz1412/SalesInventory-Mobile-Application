<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@android:color/white">

    <TextView
        android:id="@+id/tvDetailWalletName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Wallet Name"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="?attr/colorPrimary"
        android:gravity="center" />

    <TextView
        android:id="@+id/tvDetailWalletNumber"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="09123456789"
        android:textSize="14sp"
        android:textColor="#555"
        android:gravity="center"
        android:visibility="gone"
        android:layout_marginTop="4dp"/>

    <TextView
        android:id="@+id/tvDetailBalance"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="₱0.00"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:gravity="center"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnResetCash"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="RESET CASH TO ZERO (END OF SHIFT)"
        android:textColor="@android:color/white"
        android:backgroundTint="@color/errorRed"
        android:visibility="gone"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Recent Transactions"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <ListView
        android:id="@+id/lvWalletHistory"
        android:layout_width="match_parent"
        android:layout_height="250dp"
        android:divider="@null"
        android:dividerHeight="4dp"/>

    <Button
        android:id="@+id/btnCloseDetail"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Close"
        android:layout_marginTop="8dp"/>
</LinearLayout>