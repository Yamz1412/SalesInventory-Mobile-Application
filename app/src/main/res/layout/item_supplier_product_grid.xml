<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="6dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="?android:colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <!-- Left icon placeholder (no image — uses a box icon instead) -->
        <LinearLayout
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/edite_round"
            android:backgroundTint="?attr/colorPrimary"
            android:layout_marginEnd="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📦"
                android:textSize="22sp" />
        </LinearLayout>

        <!-- Center: name, category badge -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginEnd="8dp">

            <TextView
                android:id="@+id/tvProductNameGrid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Product Name"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end"
                android:textColor="?attr/colorOnBackground" />

            <!-- Category badge -->
            <TextView
                android:id="@+id/tvProductCategoryGrid"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Category"
                android:textSize="11sp"
                android:textColor="?attr/colorPrimary"
                android:background="@drawable/edite_round"
                android:backgroundTint="#E8EAF6"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:layout_marginTop="4dp"
                android:visibility="gone" />

            <!-- Stock count -->
            <TextView
                android:id="@+id/tvProductStockGrid"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Stock: 0 pcs"
                android:textSize="11sp"
                android:textColor="#757575"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- Right: price -->
        <TextView
            android:id="@+id/tvProductPriceGrid"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="₱0.00"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/successGreen" />

    </LinearLayout>
</androidx.cardview.widget.CardView>