<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginBottom="8dp">

    <!-- Main row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:weightSum="7.5">

        <EditText
            android:id="@+id/etProductNameEntry"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2.5"
            android:hint="Product Name"
            android:textSize="13sp"
            android:background="@drawable/edite_round"
            android:padding="12dp"
            android:layout_marginEnd="4dp"
            android:inputType="textCapWords" />

        <EditText
            android:id="@+id/etProductQty"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Qty"
            android:textSize="13sp"
            android:inputType="number"
            android:background="@drawable/edite_round"
            android:padding="12dp"
            android:layout_marginEnd="4dp"/>

        <Spinner
            android:id="@+id/spinnerMeasurementType"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1.5"
            android:background="@drawable/edite_round"
            android:layout_marginEnd="4dp"/>

        <EditText
            android:id="@+id/etPcsPerPack"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Pcs per pack/box"
            android:visibility="gone"
            android:textSize="13sp"
            android:inputType="number"
            android:background="@drawable/edite_round"
            android:padding="12dp"
            android:layout_marginEnd="4dp"/>

        <EditText
            android:id="@+id/etProductCost"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Cost ₱"
            android:textSize="13sp"
            android:inputType="numberDecimal"
            android:background="@drawable/edite_round"
            android:padding="12dp"
            android:layout_marginEnd="4dp"/>

        <ImageButton
            android:id="@+id/btnDeleteProductRow"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_delete"
            app:tint="@color/errorRed" />

    </LinearLayout>
</LinearLayout>