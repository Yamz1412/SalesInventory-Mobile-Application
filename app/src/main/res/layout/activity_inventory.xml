<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="8dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="?attr/colorSurface">

            <LinearLayout
                android:id="@+id/llStats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Inventory Management"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Total Products"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorOnSurface"
                            android:alpha="0.7" />

                        <TextView
                            android:id="@+id/TotalCountTV"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="32sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorOnSurface" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="end"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Alerts"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorOnSurface"
                            android:alpha="0.7" />

                        <TextView
                            android:id="@+id/tvLowStockWarning"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 alerts"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="#F57F17"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/tvAllClear"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✓ All clear"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#4CAF50"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp"
            android:paddingBottom="8dp"
            android:weightSum="3">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_add_product"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="+ Add"
                android:textSize="12sp"
                android:minHeight="48dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:layout_marginEnd="4dp"
                style="@style/CustomButtonOutlined"
                android:textColor="?attr/colorOnPrimary"
                app:backgroundTint="?attr/colorPrimary"
                app:cornerRadius="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_adjust_stock"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Adjust"
                android:textSize="12sp"
                android:minHeight="48dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:layout_marginHorizontal="2dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="?attr/colorOnBackground"
                android:textColor="?attr/colorOnBackground"
                app:cornerRadius="8dp"/>

            <FrameLayout
                android:id="@+id/layout_archive_container"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:visibility="gone">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_archive"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Archive"
                    android:textSize="12sp"
                    android:minHeight="48dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    app:strokeColor="?attr/colorOnBackground"
                    android:textColor="?attr/colorOnBackground"
                    app:cornerRadius="8dp"/>

                <TextView
                    android:id="@+id/tvArchiveBadge"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="-4dp"
                    android:layout_marginEnd="-4dp"
                    android:background="@drawable/bg_notification_badge"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:elevation="4dp"
                    android:text="0" />
            </FrameLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp"
            android:paddingBottom="8dp"
            android:gravity="center_vertical">

            <SearchView
                android:id="@+id/searchView"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:queryHint="Search products..."
                android:iconifiedByDefault="false"
                android:background="@drawable/edite_round"
                android:backgroundTint="?attr/colorSurface" />

            <Spinner
                android:id="@+id/spinnerSort"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_marginStart="8dp"
                android:backgroundTint="?attr/colorControlHighlight"
                android:background="@drawable/edite_round" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp"
            android:paddingBottom="8dp"
            android:weightSum="2">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Brand Filter:"
                    android:textSize="11sp"
                    android:textColor="?attr/colorOnBackground"
                    android:layout_marginBottom="4dp"/>

                <Spinner
                    android:id="@+id/spinnerCategoryFilter"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:backgroundTint="?attr/colorControlHighlight"
                    android:background="@drawable/edite_round" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Category Filter:"
                    android:textSize="11sp"
                    android:textColor="?attr/colorOnBackground"
                    android:layout_marginBottom="4dp"/>

                <Spinner
                    android:id="@+id/spinnerProductLineFilter"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:backgroundTint="?attr/colorControlHighlight"
                    android:background="@drawable/edite_round" />
            </LinearLayout>
            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchShowOutOfStock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginBottom="8dp"
                android:text="Show out-of-stock"
                android:textColor="?attr/colorOnSurface" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="16dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/emptyStateTV"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No products found"
            android:gravity="center"
            android:textSize="16sp"
            android:textColor="?attr/colorOnBackground"
            android:visibility="gone"
            android:padding="20dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/productsRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="4dp"
            android:clipToPadding="false"
            android:paddingBottom="80dp"
            tools:listitem="@layout/item_inventory"
            tools:itemCount="6" />
    </LinearLayout>

    <View
        android:id="@+id/fab_bg_dimmer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"
        android:visibility="gone"
        android:elevation="6dp" />

</RelativeLayout>