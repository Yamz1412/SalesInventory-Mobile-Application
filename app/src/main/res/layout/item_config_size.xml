<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginBottom="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp"
        android:weightSum="3">

        <Spinner
            android:id="@+id/spinnerLinkedInventory"
            android:layout_width="0dp"
            android:layout_height="45dp"
            android:layout_weight=".7"
            android:background="@drawable/edite_round"
            android:layout_marginEnd="4dp"/>

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggleHotCold"
            android:layout_width="0dp"
            android:layout_height="45dp"
            android:layout_weight="1.4"
            android:layout_marginEnd="4dp"
            app:singleSelection="true"
            app:selectionRequired="true"
            app:checkedButton="@+id/btnHot">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnHot"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Hot"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCold"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Cold"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
        </com.google.android.material.button.MaterialButtonToggleGroup>

        <EditText
            android:id="@+id/etSizePrice"
            android:layout_width="0dp"
            android:layout_height="45dp"
            android:layout_weight="0.8"
            android:hint="+ Price Diff"
            android:textSize="14sp"
            android:inputType="numberDecimal"
            android:background="@drawable/edite_round"
            android:padding="12dp"
            android:layout_marginEnd="4dp"/>

        <ImageButton
            android:id="@+id/btnDelete"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_delete"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/errorRed"/>
    </LinearLayout>

</LinearLayout>