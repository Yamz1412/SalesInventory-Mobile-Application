<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground"
    tools:context=".MainActivity">

    <LinearLayout
        android:id="@+id/layout_impersonation_banner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorError"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:elevation="6dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_impersonation_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="👀 Viewing layout as Staff"
            android:textColor="?attr/colorOnError"
            android:textStyle="bold"
            android:textSize="14sp"/>

        <Button
            android:id="@+id/btn_exit_impersonation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minHeight="40dp"
            android:text="Exit View"
            android:backgroundTint="?attr/colorOnError"
            android:textColor="?attr/colorError" />
    </LinearLayout>

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe_refresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="72dp">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/main_scroll_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:clipToPadding="false"
            android:paddingBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <ImageView
                        android:id="@+id/ivBusinessLogo"
                        android:layout_width="46dp"
                        android:layout_height="46dp"
                        android:scaleType="centerCrop"
                        android:backgroundTint="?attr/colorOnSurface"
                        android:background="@drawable/bg_circle_light"
                        android:layout_marginEnd="12dp"
                        android:visibility="gone" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvBusinessName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Dashboard"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorOnBackground"
                            android:maxLines="1"
                            android:ellipsize="end" />

                        <TextView
                            android:id="@+id/tv_last_updated"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Updated just now"
                            android:textSize="12sp"
                            android:textColor="?attr/colorOnBackground"
                            android:alpha="0.7"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <FrameLayout
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_marginStart="4dp">

                        <ImageButton
                            android:id="@+id/btn_notifications"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:padding="10dp"
                            android:src="@drawable/ic_notifications"
                            app:tint="?attr/colorOnBackground"
                            android:contentDescription="notifications"
                            android:onClick="onNotificationsClicked"
                            android:scaleType="centerInside" />

                        <TextView
                            android:id="@+id/tv_notification_badge"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_gravity="end|top"
                            android:layout_marginTop="6dp"
                            android:layout_marginEnd="6dp"
                            android:visibility="gone"
                            android:gravity="center"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorOnError"
                            android:background="@drawable/bg_notification_badge"
                            android:elevation="2dp" />
                    </FrameLayout>

                    <ImageButton
                        android:id="@+id/btn_settings"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:padding="10dp"
                        android:src="@drawable/ic_settings"
                        app:tint="?attr/colorOnBackground"
                        android:scaleType="centerInside"
                        android:contentDescription="settings" />

                    <ImageButton
                        android:id="@+id/btn_profile"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:padding="10dp"
                        android:src="@drawable/ic_profile"
                        app:tint="?attr/colorOnBackground"
                        android:scaleType="centerInside"
                        android:contentDescription="profile" />
                </LinearLayout>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:layout_marginBottom="16dp">

                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/toggle_time_filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:singleSelection="true"
                        app:selectionRequired="true"
                        app:checkedButton="@id/btn_filter_daily">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_filter_daily"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Daily"
                            android:textSize="12sp"
                            android:minHeight="40dp"
                            app:backgroundTint="?attr/colorSurface"
                            android:textColor="?attr/colorOnSurface"
                            app:strokeColor="?attr/colorOnSurface"
                            app:cornerRadius="20dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_filter_weekly"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Weekly"
                            android:textSize="12sp"
                            android:minHeight="40dp"
                            app:backgroundTint="?attr/colorSurface"
                            android:textColor="?attr/colorOnSurface"
                            app:strokeColor="?attr/colorOnSurface"
                            app:cornerRadius="20dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_filter_monthly"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Monthly"
                            android:textSize="12sp"
                            android:minHeight="40dp"
                            app:backgroundTint="?attr/colorSurface"
                            android:textColor="?attr/colorOnSurface"
                            app:strokeColor="?attr/colorOnSurface"
                            app:cornerRadius="20dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_filter_all_time"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="All Time"
                            android:textSize="12sp"
                            android:minHeight="40dp"
                            app:backgroundTint="?attr/colorSurface"
                            android:textColor="?attr/colorOnSurface"
                            app:strokeColor="?attr/colorOnSurface"
                            app:cornerRadius="20dp" />
                    </com.google.android.material.button.MaterialButtonToggleGroup>
                </HorizontalScrollView>

                <ProgressBar
                    android:id="@+id/progress_bar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:visibility="gone"
                    android:indeterminate="true" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Café Overview"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnBackground" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Today's live brewing metrics"
                        android:textSize="13sp"
                        android:alpha="0.7"
                        android:textColor="?attr/colorOnBackground" />
                </LinearLayout>

                <GridLayout
                    android:id="@+id/dashboard_grid"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:alignmentMode="alignMargins"
                    android:columnOrderPreserved="false"
                    android:paddingHorizontal="10dp">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="6dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="?attr/colorSurface">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="@drawable/edite_round"
                                android:backgroundTint="#FFF8E1"
                                android:padding="6dp"
                                android:src="@drawable/ic_sales"
                                app:tint="#F57F17"
                                android:layout_marginBottom="12dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Today's Sales"
                                android:textSize="12sp"
                                android:textColor="?attr/colorOnSurface"
                                android:alpha="0.8" />

                            <TextView
                                android:id="@+id/tvTotalSales"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="₱0.00"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:textColor="?attr/colorOnSurface"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="6dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="?attr/colorSurface">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="@drawable/edite_round"
                                android:backgroundTint="#E8F5E9"
                                android:padding="6dp"
                                android:src="@drawable/ic_purchase"
                                app:tint="#2E7D32"
                                android:layout_marginBottom="12dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Today's Profit"
                                android:textSize="12sp"
                                android:textColor="?attr/colorOnSurface"
                                android:alpha="0.8" />

                            <TextView
                                android:id="@+id/tvTotalProfit"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="₱0.00"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:textColor="?attr/colorOnSurface"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="6dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="?attr/colorSurface">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="@drawable/edite_round"
                                android:backgroundTint="#FFE082"
                                android:padding="6dp"
                                android:src="@drawable/ic_warning"
                                app:tint="#E65100"
                                android:layout_marginBottom="12dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Running Low"
                                android:textSize="12sp"
                                android:textColor="#E65100" />

                            <TextView
                                android:id="@+id/tvLowStock"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 Items"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="#E65100"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:layout_margin="6dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="?attr/colorSurface">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="@drawable/edite_round"
                                android:backgroundTint="#C5CAE9"
                                android:padding="6dp"
                                android:src="@drawable/ic_purchase_order"
                                app:tint="#283593"
                                android:layout_marginBottom="12dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Incoming POs"
                                android:textSize="12sp"
                                android:textColor="#283593" />

                            <TextView
                                android:id="@+id/tvPendingOrders"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 Orders"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="#283593"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </GridLayout>

                <androidx.cardview.widget.CardView
                    android:id="@+id/card_near_expiry"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="6dp"
                    android:layout_marginBottom="16dp"
                    android:visibility="gone"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="?attr/colorSurface">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical">
                        <ImageView android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_inventory" app:tint="#F57F17" android:layout_marginEnd="12dp"/>
                        <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⏳ ACTION REQUIRED: EXPIRING SOON" android:textSize="12sp" android:textStyle="bold" android:textColor="#F57F17" />
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="4dp">
                                <TextView android:id="@+id/tv_near_expiry_count" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="14sp" android:textStyle="bold" android:textColor="#E65100" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=" items expiring within 7 days" android:textSize="14sp" android:textColor="#E65100" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <TextView android:id="@+id/tv_sales_amount" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
                <TextView android:id="@+id/tv_gross_profit" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
                <TextView android:id="@+id/tv_opex" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
                <TextView android:id="@+id/tv_net_income" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_manage_users"
                    style="@style/CustomButtonOutlined"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Manage Users &amp; Staff"
                    android:layout_marginTop="4dp"
                    android:textColor="?attr/colorOnSurface"
                    app:backgroundTint="?attr/colorSurface"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Analytics"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnBackground"
                    android:layout_marginBottom="12dp" />

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="?attr/colorSurface">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sales Trend (7 Days)"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorOnSurface" />

                        <com.github.mikephil.charting.charts.LineChart
                            android:id="@+id/chart_sales_trend"
                            android:layout_width="match_parent"
                            android:layout_height="200dp"
                            android:layout_marginTop="12dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:baselineAligned="false">

                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:layout_marginBottom="16dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="?attr/colorSurface">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Top Products"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="?attr/colorOnSurface" />

                            <com.github.mikephil.charting.charts.BarChart
                                android:id="@+id/chart_top_products"
                                android:layout_width="match_parent"
                                android:layout_height="180dp"
                                android:layout_marginTop="12dp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:layout_marginBottom="16dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="?attr/colorSurface">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Inventory"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="?attr/colorOnSurface" />

                            <com.github.mikephil.charting.charts.PieChart
                                android:id="@+id/chart_inventory_status"
                                android:layout_width="match_parent"
                                android:layout_height="180dp"
                                android:layout_marginTop="12dp" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Recent Activity"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnBackground"
                    android:layout_marginBottom="12dp" />

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="?attr/colorSurface">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_recent_activity"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        tools:listitem="@layout/item_recent_activity"
                        tools:itemCount="3"
                        android:paddingVertical="8dp" />
                </androidx.cardview.widget.CardView>

                <GridLayout android:id="@+id/quick_actions_grid" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <com.google.android.material.bottomappbar.BottomAppBar
        android:id="@+id/bottom_app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        app:backgroundTint="?attr/colorSurface"
        app:fabAlignmentMode="center"
        app:fabCradleMargin="10dp"
        app:fabCradleRoundedCornerRadius="24dp"
        app:fabCradleVerticalOffset="8dp"
        app:elevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="4dp"
            android:paddingTop="6dp"
            android:paddingBottom="4dp">

            <LinearLayout
                android:id="@+id/btn_inventory"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:paddingVertical="4dp">
                <ImageView android:layout_width="26dp" android:layout_height="26dp" android:src="@drawable/ic_inventory" app:tint="?attr/colorOnSurface"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Inventory" android:textSize="11sp" android:textColor="?attr/colorOnSurface" android:layout_marginTop="4dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_create_sale"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:paddingVertical="4dp">
                <ImageView android:layout_width="26dp" android:layout_height="26dp" android:src="@drawable/ic_add_sale" app:tint="?attr/colorOnSurface"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Create Sales" android:textSize="11sp" android:textColor="?attr/colorOnSurface" android:layout_marginTop="4dp"/>
            </LinearLayout>

            <View android:layout_width="60dp" android:layout_height="0dp" />

            <LinearLayout
                android:id="@+id/btn_create_po"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:paddingVertical="4dp">
                <ImageView android:layout_width="26dp" android:layout_height="26dp" android:src="@drawable/ic_purchase_order" app:tint="?attr/colorOnSurface"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Purchase Order" android:textSize="11sp" android:textColor="?attr/colorOnSurface" android:layout_marginTop="4dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_view_reports"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:paddingVertical="4dp">
                <ImageView android:layout_width="26dp" android:layout_height="26dp" android:src="@drawable/ic_reports" app:tint="?attr/colorOnSurface"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Reports" android:textSize="11sp" android:textColor="?attr/colorOnSurface" android:layout_marginTop="4dp"/>
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.bottomappbar.BottomAppBar>

    <View
        android:id="@+id/dim_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"
        android:visibility="gone"
        android:elevation="6dp" />

    <LinearLayout
        android:id="@+id/layout_fab_menu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="90dp"
        android:gravity="end"
        android:visibility="gone"
        android:elevation="7dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Suggested Catalog"
                android:textColor="?attr/colorOnSurface"
                android:textStyle="bold"
                android:background="@drawable/edite_round"
                android:backgroundTint="?attr/colorSurface"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:layout_marginEnd="12dp"/>

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fab_suggested_product"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:fabSize="mini"
                app:srcCompat="@android:drawable/ic_menu_search"
                app:tint="?attr/colorPrimary"
                app:backgroundTint="?attr/colorSurface" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add Manually"
                android:textColor="?attr/colorOnSurface"
                android:textStyle="bold"
                android:background="@drawable/edite_round"
                android:backgroundTint="?attr/colorSurface"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:layout_marginEnd="12dp"/>

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fab_add_manual"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:fabSize="mini"
                app:srcCompat="@android:drawable/ic_input_add"
                app:tint="?attr/colorPrimary"
                app:backgroundTint="?attr/colorSurface"/>
        </LinearLayout>
    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btn_add_product"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_anchor="@id/bottom_app_bar"
        app:srcCompat="@android:drawable/ic_input_add"
        app:tint="?attr/colorAccent"
        app:backgroundTint="?attr/colorOnSurface"
        style="@style/CustomButtonOutlined"
        android:contentDescription="Expand Menu" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>